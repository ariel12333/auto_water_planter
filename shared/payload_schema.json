{
    "version": "2.0",
    "description": "ESP32 Sensor Hub structured payload schema (OOP)",
    "board_fields": [
        {
            "name": "device_id",
            "type": "string",
            "description": "Unique hardware identifier"
        },
        {
            "name": "sensor_name",
            "type": "string",
            "description": "Human-readable name (e.g. Garden)"
        },
        {
            "name": "temperature",
            "type": "number",
            "description": "Chip temperature in °C"
        },
        {
            "name": "rssi",
            "type": "integer",
            "description": "WiFi signal strength in dBm"
        },
        {
            "name": "uptime",
            "type": "integer",
            "description": "Seconds since boot"
        },
        {
            "name": "boot_count",
            "type": "integer",
            "description": "Number of boots"
        }
    ],
    "sensor_fields": [
        {
            "name": "name",
            "type": "string",
            "description": "Name of the sensor feature (e.g. Moisture)"
        },
        {
            "name": "measurement",
            "type": "number",
            "description": "Calculated value"
        },
        {
            "name": "units",
            "type": "string",
            "description": "Measurement unit (e.g. '%', 'C')"
        },
        {
            "name": "channel_in",
            "type": "integer",
            "description": "Input GPIO pin"
        },
        {
            "name": "channel_out",
            "type": "integer",
            "description": "Output/Power GPIO pin (if any)"
        }
    ]
}